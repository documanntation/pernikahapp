rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Resources Collection
    // Public can read resources
    // Admin can write, or anyone can update ONLY the likes count
    match /resources/{resourceId} {
      allow read: if true;
      allow create: if isValidId(resourceId) && isValidResource(incoming());
      allow update: if isValidId(resourceId) && (
        // Allow public to increment likes only
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes']) && incoming().likes is number) ||
        // Admin full update
        isValidResource(incoming())
      );
      allow delete: if true;
    }

    function isValidResource(data) {
      return data.keys().hasAll(['title', 'description', 'category', 'resourceType', 'url'])
        && data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 2000
        && data.category is string && data.category.size() <= 100
        && data.resourceType is string && data.resourceType.size() <= 50
        && data.url is string && data.url.size() <= 1000
        && (!data.keys().contains('likes') || data.likes is number)
        && (!data.keys().contains('creator') || (data.creator is string && data.creator.size() <= 200))
        && (!data.keys().contains('thumbnailUrl') || (data.thumbnailUrl is string && data.thumbnailUrl.size() <= 1500));
    }

    // User Submissions (Requests & Recommendations)
    match /user_submissions/{submissionId} {
      allow read: if true; 
      allow create: if isValidId(submissionId) && isValidSubmission(incoming());
      allow update: if isValidId(submissionId) && (
        // Specific user editing their submission
        (isValidSubmission(incoming()) && incoming().createdAt == existing().createdAt) ||
        // Or anyone just incrementing likes/votes on the submission
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'updatedAt']) && incoming().likes is number)
      );
      allow delete: if true;
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['title', 'description', 'category', 'isRequest', 'submittedBy'])
        && data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 2000
        && data.category is string && data.category.size() <= 100
        && data.isRequest is bool
        && data.submittedBy is string && data.submittedBy.size() <= 200
        && (!data.keys().contains('url') || (data.url is string && data.url.size() <= 1000))
        && (!data.keys().contains('resourceType') || (data.resourceType is string && data.resourceType.size() <= 50))
        && (!data.keys().contains('likes') || data.likes is number);
    }
  }
}
