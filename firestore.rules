rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Resources Collection
    // Public can read resources
    // Admin can write, or anyone can update ONLY the likes count
    match /resources/{resourceId} {
      allow read: if true;
      allow create: if isValidId(resourceId) && isValidResource(incoming());
      allow update: if isValidId(resourceId) && (
        // Allow public to increment likes only
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes']) && incoming().likes is number) ||
        // Admin full update
        isValidResource(incoming())
      );
      allow delete: if true;
    }

    function isValidResource(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.description is string && data.description.size() > 0 && data.description.size() <= 2000
        && data.category is string && data.category.size() > 0 && data.category.size() <= 100;
    }

    // User Submissions (Requests & Recommendations)
    match /user_submissions/{submissionId} {
      allow read: if true; 
      allow create: if isValidSubmission(incoming());
      allow update: if isValidId(submissionId) && (
        // Specific user editing their submission
        (isValidSubmission(incoming()) && incoming().createdAt == existing().createdAt) ||
        // Or anyone just incrementing likes/votes on the submission
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'updatedAt']) && incoming().likes is number)
      );
      allow delete: if true;
    }

    function isValidSubmission(data) {
      return data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 2000
        && data.category is string && data.category.size() <= 100
        && data.submittedBy is string && data.submittedBy.size() <= 200;
    }
  }
}
